@page "{id:int}"
@model CinemaApp.Pages.Halls.DeleteModel
@{ ViewData["Title"] = "Видалити зал"; }
<h2>Видалити зал?</h2><hr />
<div class="alert alert-warning">Зал: <strong>@Model.Hall.Name</strong> (місткість: @Model.Hall.Capacity)</div>
<form method="post">
    <button type="submit" class="btn btn-danger">Видалити</button>
    <a asp-page="Index" class="btn btn-secondary ms-2">Скасувати</a>
</form>
