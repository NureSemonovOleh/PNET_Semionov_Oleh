@page
@model CinemaApp.Pages.Genres.CreateModel
@{ ViewData["Title"] = "Додати жанр"; }
<h2>Додати жанр</h2><hr />
<div class="row"><div class="col-md-5">
<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Genre.Name" class="form-label"></label>
        <input asp-for="Genre.Name" class="form-control" />
        <span asp-validation-for="Genre.Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Genre.Description" class="form-label"></label>
        <textarea asp-for="Genre.Description" class="form-control" rows="3"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Зберегти</button>
    <a asp-page="Index" class="btn btn-secondary ms-2">Скасувати</a>
</form>
</div></div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
