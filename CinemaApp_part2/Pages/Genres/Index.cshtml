@page
@model CinemaApp.Pages.Genres.IndexModel
@{ ViewData["Title"] = "Жанри"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Жанри</h2>
    <a asp-page="Create" class="btn btn-primary">+ Додати жанр</a>
</div>

<table class="table table-hover">
    <thead class="table-dark"><tr><th>Назва</th><th>Опис</th><th>Фільмів</th><th>Дії</th></tr></thead>
    <tbody>
        @foreach (var g in Model.Genres)
        {
            <tr>
                <td>@g.Name</td>
                <td>@g.Description</td>
                <td><span class="badge bg-secondary">@g.Movies.Count</span></td>
                <td>
                    <a asp-page="Edit" asp-route-id="@g.GenreId" class="btn btn-sm btn-outline-secondary">Редагувати</a>
                    <a asp-page="Delete" asp-route-id="@g.GenreId" class="btn btn-sm btn-outline-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>
