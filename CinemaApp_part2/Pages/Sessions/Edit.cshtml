@page "{id:int}"
@model CinemaApp.Pages.Sessions.EditModel
@{
    ViewData["Title"] = "Редагувати сеанс";
}

<h2>Редагувати сеанс</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <input type="hidden" asp-for="Session.SessionId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Session.MovieId" class="form-label"></label>
                <select asp-for="Session.MovieId" asp-items="Model.Movies" class="form-select"></select>
                <span asp-validation-for="Session.MovieId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Session.HallId" class="form-label"></label>
                <select asp-for="Session.HallId" asp-items="Model.Halls" class="form-select"></select>
                <span asp-validation-for="Session.HallId" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Session.SessionDate" class="form-label"></label>
                    <input asp-for="Session.SessionDate" class="form-control" type="date" />
                    <span asp-validation-for="Session.SessionDate" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="Session.StartTime" class="form-label"></label>
                    <input asp-for="Session.StartTime" class="form-control" type="time" />
                    <span asp-validation-for="Session.StartTime" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Session.TicketPrice" class="form-label"></label>
                    <input asp-for="Session.TicketPrice" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Session.TicketPrice" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="Session.TicketsSold" class="form-label"></label>
                    <input asp-for="Session.TicketsSold" class="form-control" type="number" />
                    <span asp-validation-for="Session.TicketsSold" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Зберегти</button>
            <a asp-page="Index" class="btn btn-secondary ms-2">Скасувати</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
