@page
@model CinemaApp.Pages.Sessions.IndexModel
@{
    ViewData["Title"] = "Сеанси";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Сеанси</h2>
    <a asp-page="Create" class="btn btn-primary">+ Додати сеанс</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Sessions.Any())
{
    <div class="alert alert-info">Сеансів ще немає.</div>
}
else
{
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Фільм</th>
                <th>Зал</th>
                <th>Дата</th>
                <th>Час</th>
                <th>Ціна</th>
                <th>Продано / Місць</th>
                <th>Виручка</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Sessions)
            {
                <tr>
                    <td>@s.Movie?.Title</td>
                    <td>@s.Hall?.Name</td>
                    <td>@s.SessionDate.ToString("dd.MM.yyyy")</td>
                    <td>@s.StartTime.ToString("HH:mm")</td>
                    <td>@s.TicketPrice.ToString("F2") грн</td>
                    <td>
                        <span class="badge @(s.TicketsSold >= s.Hall?.Capacity ? "bg-danger" : "bg-success")">
                            @s.TicketsSold / @s.Hall?.Capacity
                        </span>
                    </td>
                    <td>@s.Revenue.ToString("F0") грн</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@s.SessionId" class="btn btn-sm btn-outline-secondary">Редагувати</a>
                        <a asp-page="Delete" asp-route-id="@s.SessionId" class="btn btn-sm btn-outline-danger">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
