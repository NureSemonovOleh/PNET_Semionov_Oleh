<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Кінотеатр</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-page="/Index">🎬 Кінотеатр</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navmenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navmenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-page="/Movies/Index">Фільми</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Sessions/Index">Сеанси</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Directors/Index">Режисери</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Genres/Index">Жанри</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Halls/Index">Зали</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="footer mt-5 py-3 bg-dark text-white text-center">
        <span>Система управління кінотеатром &copy; 2026</span>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
